# Frontend environment variables
# Copy this to .env and fill in values as needed.
# Do NOT commit .env to version control.

# Set to "true" to show the paid-API toggle and Google sign-in button in the UI.
# When false (default), no paid-API UI is rendered and the app runs entirely on
# free/open endpoints (Overpass, Open-Meteo, Nominatim).
VITE_ENABLE_PAID_APIS=true
