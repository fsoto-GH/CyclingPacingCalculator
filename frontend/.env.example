# Frontend environment variables
# Copy this to .env and fill in values as needed.
# Do NOT commit .env to version control.

# Set to "true" to enable server-dependent features: Google sign-in, Search
# RideWithGPS, and My Race Plans. When false the app runs fully serverless.
# Free endpoints (Overpass, Open-Meteo, Nominatim) are always available.
VITE_ENABLE_SERVER_FUNCTIONS=true

# Supabase project credentials (safe to expose in frontend bundle).
# Find these in Supabase dashboard: Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Google OAuth web client ID used by Google One Tap + pre-built Google button.
# Create in Google Cloud Console -> Google Auth Platform -> Clients.
VITE_GOOGLE_CLIENT_ID=<google-web-client-id>
